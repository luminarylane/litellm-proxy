# Local host-run mode: copy to .env before running ./local/setup.sh.
# You operate Redis and Postgres outside Docker.

# Required for OpenAI-backed virtual profiles.
OPENAI_API_KEY=your-openai-api-key

# Required for Gemini-backed virtual profiles.
GEMINI_API_KEY=your-primary-gemini-api-key
GEMINI_API_KEY_ALT=your-secondary-gemini-api-key

# LiteLLM administrator key used to register the virtual keys below.
LITELLM_MASTER_KEY=replace-with-a-strong-admin-key

# Keep this stable after the first start: LiteLLM uses it to encrypt stored
# provider credentials. Generate a long random value for organization use.
LITELLM_SALT_KEY=replace-with-a-strong-stable-salt-key

# Host port used by the local proxy.
LITELLM_PORT=4000

# External database backing the local proxy. A Supabase free-tier database
# needs its IPv4 pooled connection string (typically port 6543).
# See: https://github.com/orgs/supabase/discussions/33534#discussioncomment-12234453
LITELLM_DATABASE_URL=postgresql://litellm:litellm@localhost:5432/litellm?connection_limit=1&pool_timeout=10

# Conservative limits for constrained external Postgres services such as
# Supabase free-tier. Increase only after sizing the external database.
LITELLM_DATABASE_CONNECTION_POOL_LIMIT=1
LITELLM_DATABASE_POOL_SIZE=1
LITELLM_DATABASE_MAX_OVERFLOW=0

# Write LiteLLM request/spend logs asynchronously so model requests are not
# blocked on database logging. Set to False only when synchronous logging is required.
LITELLM_ASYNC_LOGGING=True

# Optional custom credentials for the LiteLLM proxy UI.
# If unset, log in to http://localhost:4000/ui with username "admin" and
# LITELLM_MASTER_KEY as the password.
UI_USERNAME=
UI_PASSWORD=

# Virtual keys consumed by the included Claude Code launchers.
LITELLM_OPENAI_VIRTUAL_KEY=sk-claude-code-openai
LITELLM_OPENAI_5_6_VIRTUAL_KEY=sk-claude-code-openai-5-6
LITELLM_GEMINI_VIRTUAL_KEY=sk-claude-code-gemini
