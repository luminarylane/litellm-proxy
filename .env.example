# Copy this file to `.env` and fill in the values before running the proxy.
#
# Required for OpenAI-backed virtual profile.
OPENAI_API_KEY=your-openai-api-key

# Required for Gemini-backed virtual profile.
GEMINI_API_KEY=your-primary-gemini-api-key
GEMINI_API_KEY_ALT=your-secondary-gemini-api-key

# LiteLLM admin key used to register the virtual keys below.
LITELLM_MASTER_KEY=replace-with-a-strong-local-admin-key

# Local database backing the LiteLLM proxy.
# Example:
# LITELLM_DATABASE_URL=postgresql://litellm:litellm@localhost:5432/litellm
LITELLM_DATABASE_URL=postgresql://litellm:litellm@localhost:5432/litellm

# Virtual keys consumed by the included Claude Code tmux launchers.
LITELLM_OPENAI_VIRTUAL_KEY=sk-claude-code-openai
LITELLM_GEMINI_VIRTUAL_KEY=sk-claude-code-gemini
