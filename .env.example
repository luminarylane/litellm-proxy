# Copy this file to `.env` and fill in the values before running the proxy.
#
# Required for OpenAI-backed virtual profile.
OPENAI_API_KEY=your-openai-api-key

# Required for Gemini-backed virtual profile.
GEMINI_API_KEY=your-primary-gemini-api-key
GEMINI_API_KEY_ALT=your-secondary-gemini-api-key

# LiteLLM admin key used to register the virtual keys below.
LITELLM_MASTER_KEY=replace-with-a-strong-local-admin-key

# Keep this stable after the first start: LiteLLM uses it to encrypt stored
# provider credentials. Generate a long random value for organization use.
LITELLM_SALT_KEY=replace-with-a-strong-stable-salt-key

# Used only by Docker Compose for its self-contained Postgres service.
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

# Host port exposed by Docker Compose and used by the local run scripts.
LITELLM_PORT=4000

# Optional: custom credentials for the LiteLLM proxy UI.
# If unset, log in to http://localhost:4000/ui with username "admin" and
# LITELLM_MASTER_KEY as the password.
UI_USERNAME=
UI_PASSWORD=

# Local database backing the LiteLLM proxy.
# A Supabase free-tier Postgres works; use the IPv4 pooled connection string
# (port 6543) or the connection will fail from most local networks.
# See: https://github.com/orgs/supabase/discussions/33534#discussioncomment-12234453
# Example:
# LITELLM_DATABASE_URL=postgresql://litellm:litellm@localhost:5432/litellm
LITELLM_DATABASE_URL=postgresql://litellm:litellm@localhost:5432/litellm?connection_limit=1&pool_timeout=10

# Virtual keys consumed by the included Claude Code tmux launchers.
LITELLM_OPENAI_VIRTUAL_KEY=sk-claude-code-openai
LITELLM_OPENAI_5_6_VIRTUAL_KEY=sk-claude-code-openai-5-6
LITELLM_GEMINI_VIRTUAL_KEY=sk-claude-code-gemini
